@model dynamic
@{
    ViewData["Title"] = "Koli Detayı";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int koliId = ViewData["KoliId"] != null ? Convert.ToInt32(ViewData["KoliId"]) : 0;
}

<!--begin::Content-->
<div class="content d-flex flex-column flex-column-fluid" id="kt_content">
    <!--begin::Toolbar-->
    <div class="toolbar" id="kt_toolbar">
        <div id="kt_toolbar_container" class="container-fluid d-flex flex-stack">
            <div data-kt-swapper="true" data-kt-swapper-mode="prepend" class="page-title d-flex align-items-center flex-wrap me-3 mb-5 mb-lg-0">
                <h1 class="d-flex align-items-center text-dark fw-bolder my-1 fs-3">
                    <span class="bullet bg-warning align-self-end me-3"></span>
                    Koli Detayı
                </h1>
            </div>
            <div class="d-flex align-items-center gap-2">
                <a href="/Arsiv/Index" class="btn btn-light-primary">
                    <i class="fas fa-arrow-left"></i> Geri Dön
                </a>
            </div>
        </div>
    </div>
    <!--end::Toolbar-->

    <!--begin::Post-->
    <div class="post d-flex flex-column-fluid" id="kt_post">
        <div id="kt_content_container" class="container-fluid">
            <!--begin::Details Card-->
            <div class="card card-xl-stretch mb-5 mb-xl-8">
                <div class="card-header border-0 pt-5">
                    <h3 class="card-title align-items-start flex-column">
                        <span class="card-label fw-bolder fs-3 mb-1" id="koliNo">-</span>
                        <span class="text-muted mt-1 fw-bold fs-7">Koli Bilgileri</span>
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row mb-8">
                        <div class="col-xl-4">
                            <div class="d-flex flex-stack">
                                <div class="me-5">
                                    <span class="text-muted fw-bold d-block lh-1">Raf Kodu</span>
                                    <span class="fs-2 fw-bolder lh-1" id="rafKod">-</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-4">
                            <div class="d-flex flex-stack">
                                <div class="me-5">
                                    <span class="text-muted fw-bold d-block lh-1">Bölme No</span>
                                    <span class="fs-2 fw-bolder lh-1" id="bolmeNo">-</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-4">
                            <div class="d-flex flex-stack">
                                <div class="me-5">
                                    <span class="text-muted fw-bold d-block lh-1">Detay</span>
                                    <span class="fs-6 fw-bold lh-1" id="detay">-</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- İçerik Listesi -->
                    <div class="separator separator-dashed my-8"></div>
                    <h4 class="fw-bolder mb-5">İçerik</h4>
                    <div id="icerikListesi" class="table-responsive">
                        <table class="table table-row-dashed table-row-gray-300 align-middle g-4">
                            <thead>
                                <tr class="fw-bolder fs-6 text-gray-800">
                                    <th>Eşya/Ad</th>
                                    <th>Miktar</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody id="icerikBody">
                                <tr>
                                    <td colspan="3" class="text-center text-muted">İçerik bulunmuyor</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadKoliDetay() {
            $.ajax({
                url: `/api/arsiv/${@koliId}`,
                method: 'GET',
                success: function(response) {
                    if (response.isSuccess && response.data) {
                        const data = response.data;
                        $('#koliNo').text(data.koliNo || 'Koli ' + data.koliId);
                        $('#rafKod').text(data.rafKod || '-');
                        $('#bolmeNo').text(data.bolmeNo || '-');
                        $('#detay').text(data.detay || '-');
                    }
                },
                error: function() {
                    toastr.error('Koli detayı yüklenemedi');
                }
            });
        }

        $(document).ready(function() {
            loadKoliDetay();
        });
    </script>
}
